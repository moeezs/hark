# ============================================================
# Hark — Environment Configuration
# ============================================================
# Step 1: Copy this file
#   cp .env.example .env
#
# Step 2: Follow the setup instructions below for each section
# Step 3: Never commit .env to git (already in .gitignore ✓)
# ============================================================


# ════════════════════════════════════════════════════════════
# GROQ API  (voice transcription only — free, no credit card)
# ════════════════════════════════════════════════════════════
#
# What it does:
#   - Transcribes your voice with Whisper (whisper-large-v3-turbo)
#
# How to get your API key:
#   1. Go to https://console.groq.com
#   2. Click "Sign Up" (or "Log In" if you already have an account)
#   3. In the left sidebar, click "API Keys"
#   4. Click "Create API Key"
#   5. Give it a name (e.g. "hark") and click "Submit"
#   6. Copy the key shown — it starts with "gsk_"
#   7. Paste it below (replace the placeholder)
#
# Free tier limits:
#   - Whisper: 6,000 minutes/day
#
GROQ_API_KEY=gsk_paste_your_key_here


# ════════════════════════════════════════════════════════════
# GEMINI API  (item extraction — free via AI Studio)
# ════════════════════════════════════════════════════════════
#
# What it does:
#   - Reads the transcript and extracts events, tasks, notes, messages
#
# How to get your API key:
#   1. Go to https://aistudio.google.com
#   2. Click "Get API key" (top left)
#   3. Click "Create API key" → choose a project (or create one)
#   4. Copy the key shown
#   5. Paste it below
#
# Model: pick any model available in AI Studio.
#   Gemma examples:  gemma-3n-e4b-it (fastest/default)  /  gemma-3-12b-it  /  gemma-3-27b-it
#   Gemini examples: gemini-2.0-flash  /  gemini-2.5-flash-preview-04-17
#   The default is gemma-3n-e4b-it (lightweight edge model) if you leave GEMINI_MODEL blank.
#
GEMINI_API_KEY=paste_your_gemini_api_key_here
GEMINI_MODEL=gemma-3n-e4b-it


# ════════════════════════════════════════════════════════════
# SNOWFLAKE  (free 30-day trial, no credit card needed)
# ════════════════════════════════════════════════════════════
#
# What it does:
#   - Stores every raw transcript + extracted items in a cloud table
#   - Table (HARK_TRANSCRIPTS) is auto-created on first connection
#
# Authentication: Programmatic Access Token (PAT)
#   Works exactly like a GitHub personal access token.
#   Generated entirely in the Snowflake web dashboard — no terminal,
#   no OpenSSL, no key files. Just click Generate and paste the token.
#   Your actual password is never stored anywhere.
#
# ── Step 1: Sign up ──────────────────────────────────────────
#   Go to https://signup.snowflake.com
#   • Choose "Standard" edition (free trial, no credit card)
#   • Pick any cloud provider + region close to you
#   • Complete signup and verify your email
#
# ── Step 2: Find your account identifier ─────────────────────
#   Log in to Snowsight (the Snowflake web UI).
#   • Click your account name in the BOTTOM-LEFT corner
#   • Hover over the account name — a copy icon appears to the right
#   • Click it to copy your account identifier
#   • It looks like:  myorg-ab12345   (NOT the full URL)
#   • Paste it as SNOWFLAKE_ACCOUNT below
#
# ── Step 3: Create the database + fix network policy ─────────
#   In Snowsight → Worksheets → open a new worksheet, then run:
#
#     CREATE DATABASE HARK_DB;
#     USE DATABASE HARK_DB;
#     CREATE WAREHOUSE IF NOT EXISTS COMPUTE_WH
#       WAREHOUSE_SIZE = 'X-SMALL'
#       AUTO_SUSPEND = 60
#       AUTO_RESUME = TRUE;
#
#   Also run these two lines so PATs work without a network policy:
#
#     CREATE AUTHENTICATION POLICY hark_pat_policy
#       PAT_POLICY=(NETWORK_POLICY_EVALUATION = NOT_ENFORCED);
#     ALTER USER <YOUR_USERNAME> SET AUTHENTICATION_POLICY = hark_pat_policy;
#
#   (Replace <YOUR_USERNAME> with your actual Snowflake username.)
#   The HARK_TRANSCRIPTS table is auto-created by Hark on first connect.
#
# ── Step 4: Generate your access token (web UI only) ─────────
#
#   In the Snowsight web UI:
#   1. In the left sidebar → Governance & Security → Users & roles
#   2. Click on YOUR username in the list
#   3. Scroll to the "Programmatic access tokens" section
#   4. Click "Generate new token"
#   5. Fill in the dialog:
#      • Name: "hark" (or any name you like)
#      • Expires in: 90 days (up to 365)
#      • Role: select your default role (e.g. ACCOUNTADMIN)
#   6. Click the three-dot (⋯) "More options" link in the dialog
#      → select "Bypass requirement for network policy"
#      (needed on trial accounts which have no network policy configured)
#   7. Click "Generate"
#   8. COPY the token immediately — you can only view it once
#
#   Paste it as SNOWFLAKE_TOKEN below.
#
SNOWFLAKE_ACCOUNT=your-org-accountname
SNOWFLAKE_USERNAME=your_snowflake_username
SNOWFLAKE_TOKEN=paste_your_programmatic_access_token_here
SNOWFLAKE_DATABASE=HARK_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH


# ════════════════════════════════════════════════════════════
# SERVER  (internal, no changes needed)
# ════════════════════════════════════════════════════════════
#
# Port for the Hark background server that Tauri auto-starts.
# Only change this if port 3847 is already in use on your machine.
#
SERVER_PORT=3847

